# Code directory (BIDS allows code/ but often excluded from validation)
code/

# Behavioral audio recordings (not officially in BIDS-EEG spec)
# Audio files are stored here for analysis convenience
**/beh/

# HDF5 EEG data files (not officially in BIDS-EEG spec)
# Using h5 format for efficient storage - documented in README
# Future releases may include EDF conversions
**/*_eeg.h5

# System files
*.pyc
__pycache__/
.DS_Store
*.swp
.git/
.gitignore

# Temporary files
*~
.*.swp
.*.swo

# Orphan sidecars (no corresponding data files yet)
task-speechopen_events.json
task-speechopen_acq-pangolin_recording-vocal_beh.json
task-speechopen_acq-scarabeo_recording-vocal_beh.json
task-speechopen_acq-eego_recording-vocal_beh.json
task-listening_acq-pangolin_recording-audio_beh.json
# Misc non-BIDS files
upload_log.txt

